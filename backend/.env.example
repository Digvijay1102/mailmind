# Resend (get from resend.com -> API Keys)
RESEND_API_KEY=re_your_key_here

# Resend webhook signing secret (without whsec_ prefix)
# Get from resend.com -> Webhooks -> your webhook -> Signing Secret
RESEND_WEBHOOK_SECRET=your_signing_secret_here

# Groq (get from console.groq.com -> API Keys)
GROQ_API_KEY=gsk_your_key_here

# LLM model — llama-3.1-8b-instant supports json_mode structured output
LLM_MODEL=llama-3.1-8b-instant

# PostgreSQL connection string
DATABASE_URL=postgresql://mailmind_user:yourpassword@localhost:5432/mailmind

# Confidence threshold below which emails go to HITL queue (0.0 to 1.0)
HITL_CONFIDENCE_THRESHOLD=0.75
